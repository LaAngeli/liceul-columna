APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=liceul_columna
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# QUEUE_CONNECTION=database: notificările (notă/absență/temă/mesaj) + emailurile + recalculul
# mediilor pleacă pe coadă. ÎN PRODUCȚIE rulează `php artisan queue:work` (sau Horizon dacă e
# Redis) — fără worker activ joburile se acumulează tăcut în tabelul `jobs` și nimic nu se livrează.
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Dev: mailer `log` (emailurile ajung în storage/logs/laravel.log, inclusiv codurile 2FA).
# PRODUCȚIE: SMTP real e OBLIGATORIU pentru codurile 2FA pe email — completează cu datele
# furnizorului (ex. serverul de mail al domeniului columna.md) și setează MAIL_MAILER=smtp:
#   MAIL_MAILER=smtp / MAIL_HOST=mail.columna.md / MAIL_PORT=587 / MAIL_SCHEME=tls
#   MAIL_USERNAME=no-reply@columna.md / MAIL_PASSWORD=…
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@columna.md"
MAIL_FROM_NAME="${APP_NAME}"

# 2FA obligatoriu la logare (rollout fazat, config/security.php): personalul imediat,
# cabinetul (elev/părinte) după anunțul școlii — comută pe true când e comunicat.
SECURITY_2FA_STAFF=true
SECURITY_2FA_CABINET=false

# Cutia poștală unde ajung mesajele din formularul public de contact (config/contact.php)
CONTACT_MAIL_TO="info@columna.org.md"

# Contul UNIC de administrare a conținutului (panoul /studio). Provizionează-l cu
# `php artisan app:cms-admin`. Parola se hash-uiește; nu ține niciodată parole reale în git.
CMS_ADMIN_EMAIL=
CMS_ADMIN_NAME="Administrator conținut"
CMS_ADMIN_PASSWORD=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
