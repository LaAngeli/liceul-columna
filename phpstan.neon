includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    paths:
        - app/
        - bootstrap/app.php
        - config/
        - database/
        - routes/

    level: 7

    # Fișiere publicate de pachete terțe (Pulse) — nu le întreținem noi.
    excludePaths:
        - config/pulse.php
        - database/migrations/*_create_pulse_tables.php
